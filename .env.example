# Beyond Code Collective — Environment Variables
# Copy this file to .env.local and fill in your values

# Anthropic — Powers the AI career guide chat in the quiz
ANTHROPIC_API_KEY=your-anthropic-api-key

# Mailchimp Marketing — Audience/contact management
# API key: https://us1.admin.mailchimp.com/account/api/
# Server prefix is the "usXX" part after the dash in your API key
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_AUDIENCE_ID=your-mailchimp-audience-id

# Resend — Sends quiz result emails (free tier: 3,000 emails/month)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=BCC Career Quiz <quiz@wearebcc.org>

# Vercel Postgres — Quiz analytics (auto-populated when provisioned in Vercel dashboard)
POSTGRES_URL=your-postgres-url

# Dashboard — Password for /dashboard access
DASHBOARD_PASSWORD=your-dashboard-password
